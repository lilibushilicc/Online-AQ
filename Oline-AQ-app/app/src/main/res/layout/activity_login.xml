<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/login_bg"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="64dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp">

            <!-- 登录卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/login_card_bg"
                app:strokeWidth="1dp"
                app:strokeColor="@color/login_card_stroke">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="40dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="学生登录"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/login_on_background"
                        android:layout_gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="使用学号或邮箱登录系统"
                        android:textSize="14sp"
                        android:textColor="@color/login_on_surface_variant"
                        android:layout_gravity="center"
                        android:layout_marginTop="4dp" />

                    <View
                        android:layout_width="48dp"
                        android:layout_height="4dp"
                        android:background="@color/login_primary"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="32dp"
                        android:layout_gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="学号 / 邮箱"
                        android:textSize="13sp"
                        android:textColor="@color/login_on_surface_variant"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/et_username"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_input_login"
                        android:paddingHorizontal="20dp"
                        android:textSize="15sp"
                        android:textColor="@color/login_on_background"
                        android:textColorHint="@color/login_input_hint"
                        android:hint="请输入您的学号或邮箱"
                        android:inputType="text"
                        android:maxLines="1"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="密码"
                        android:textSize="13sp"
                        android:textColor="@color/login_on_surface_variant"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_input_login"
                        android:paddingHorizontal="20dp"
                        android:textSize="15sp"
                        android:textColor="@color/login_on_background"
                        android:textColorHint="@color/login_input_hint"
                        android:hint="请输入登录密码"
                        android:inputType="textPassword"
                        android:maxLines="1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="24dp">

                        <TextView
                            android:id="@+id/tv_forgot_password"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="忘记密码？"
                            android:textSize="12sp"
                            android:textColor="@color/login_primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_login"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="立即登录"
                        android:textSize="16sp"
                        android:textColor="@color/login_on_primary"
                        android:textStyle="bold"
                        android:background="@drawable/bg_login_btn"
                        app:cornerRadius="12dp"
                        app:backgroundTint="@null"
                        app:elevation="0dp" />

                    <TextView
                        android:id="@+id/tv_server_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/login_hint_subtle"
                        android:layout_marginTop="20dp"
                        android:layout_gravity="center" />

                    <TextView
                        android:id="@+id/tv_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/login_error"
                        android:textSize="14sp"
                        android:visibility="gone"
                        android:layout_marginTop="12dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!-- 顶部栏（在后，覆盖在 ScrollView 之上，保证可点击） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/login_topbar_bg">

        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_logo"
            android:tint="@color/login_primary"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btn_server_settings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="服务器设置"
            android:padding="6dp"
            android:tint="@color/login_on_surface_variant" />

    </LinearLayout>

    <!-- 顶部栏底边 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="63dp"
        android:background="@color/login_divider" />

</FrameLayout>
